# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Runtime logs and temporary files
storage/logs/*
!storage/logs/.gitkeep
storage/backups/*
!storage/backups/.gitkeep

# Sensitive runtime data (contains API keys/tokens)
storage/database.json
storage/database-*.json

# User uploads
public/uploads/*
!public/uploads/.gitkeep
!public/uploads/disciplinas/
public/uploads/disciplinas/*
!public/uploads/disciplinas/.gitkeep

# Environment/local overrides
.env
.env.*
*.local

# Certificates and private keys
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore

# Dependency folders (if used)
vendor/
node_modules/
