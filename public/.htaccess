RewriteEngine On

# Webhook friendly endpoint
RewriteRule ^webhook/zapsign$ webhook/zapsign.php [QSA,L]

# Serve existing files/directories directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Forward all other requests to index.php (front controller).
RewriteRule ^ index.php [QSA,L]
